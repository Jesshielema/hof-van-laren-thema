<section class="beleid-section full-width">
  <div class="beleid-section__hero">
    <div class="beleid-section__hero-inner">
      <p class="sec-label">{{ section.settings.label | default: 'Hof van Laren' }}</p>
      <h1 class="beleid-section__heading">{{ page.title }}</h1>
      <div class="gold-rule"></div>
    </div>
  </div>

  <div class="beleid-section__body">
    <div class="beleid-section__content">
      {{ page.content }}
    </div>
  </div>
</section>

{% stylesheet %}
  .beleid-section {
    background-color: var(--color-background);
  }

  /* Hero */
  .beleid-section__hero {
    border-bottom: 1px solid var(--color-border);
    padding: 3.5rem 0 3rem;
  }

  .beleid-section__hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .beleid-section__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-foreground);
    margin: 0 0 0.5rem;
    line-height: 1.1;
  }

  /* Body */
  .beleid-section__body {
    padding: 4rem 0 6rem;
  }

  .beleid-section__content {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Typografie voor de beleidstekst */
  .beleid-section__content h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-foreground);
    margin: 2.5rem 0 0.75rem;
    line-height: 1.2;
  }

  .beleid-section__content h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 2rem 0 0.5rem;
  }

  .beleid-section__content p {
    font-size: 0.975rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-foreground);
    margin: 0 0 1.1rem;
  }

  .beleid-section__content ul,
  .beleid-section__content ol {
    padding-left: 1.25rem;
    margin: 0 0 1.1rem;
  }

  .beleid-section__content li {
    font-size: 0.975rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-foreground);
    margin-bottom: 0.4rem;
  }

  .beleid-section__content a {
    color: var(--color-gold);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s;
  }

  .beleid-section__content a:hover {
    opacity: 0.7;
  }

  .beleid-section__content strong {
    font-weight: 600;
  }

  .beleid-section__content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .beleid-section__content table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .beleid-section__content th {
    text-align: left;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gold);
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .beleid-section__content td {
    padding: 0.55rem 0;
    font-weight: 300;
    border-bottom: 1px solid rgba(216,192,163,0.4);
    vertical-align: top;
  }

  @media (max-width: 640px) {
    .beleid-section__hero {
      padding: 2.5rem 0 2rem;
    }
    .beleid-section__body {
      padding: 2.5rem 0 4rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Beleidspagina",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Bovenste label",
      "default": "Hof van Laren"
    }
  ],
  "presets": [{ "name": "Beleidspagina" }]
}
{% endschema %}
