{% comment %} Collectiepagina — luxe grid met filters en productkaarten {% endcomment %}

<div class="coll-page">
  <div class="container">

    {% comment %} Paginaheader {% endcomment %}
    <div class="coll-header">
      <div class="coll-header__text">
        <nav class="coll-breadcrumb" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span aria-hidden="true"> / </span>
          <span>{{ collection.title }}</span>
        </nav>
        <h1 class="coll-title">{{ collection.title }}</h1>
        {% if collection.description != blank %}
          <p class="coll-desc">{{ collection.description }}</p>
        {% endif %}
      </div>
      <div class="coll-header__meta">
        <span class="coll-count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'producten' }}</span>
      </div>
    </div>

    {% comment %} Sorteer & filter balk {% endcomment %}
    <div class="coll-toolbar">
      <div class="coll-filters scroll-hide">
        <a href="{{ collection.url }}" class="filter-pill {% unless current_tags %}filter-pill--active{% endunless %}">
          Alles
        </a>
        {% for tag in collection.all_tags %}
          {% if collection.current_tags contains tag %}
            <a href="{{ collection.url }}/{{ tag | handle }}" class="filter-pill filter-pill--active">
              {{ tag }}
            </a>
          {% else %}
            <a href="{{ collection.url }}/{{ tag | handle }}" class="filter-pill">
              {{ tag }}
            </a>
          {% endif %}
        {% endfor %}
      </div>

      <div class="coll-sort">
        <label for="sort-select" class="coll-sort__label">Sorteer</label>
        <select id="sort-select" class="coll-sort__select" onchange="window.location.href=this.value">
          {% assign sort_options = 'manual,best-selling,title-ascending,title-descending,price-ascending,price-descending,created-descending' | split: ',' %}
          {% assign sort_labels  = 'Aanbevolen,Best verkocht,Naam A–Z,Naam Z–A,Prijs laag–hoog,Prijs hoog–laag,Nieuwste eerst' | split: ',' %}
          {% for option in sort_options %}
            <option
              value="{{ collection.url }}?sort_by={{ option }}"
              {% if collection.sort_by == option %}selected{% endif %}
            >
              {{ sort_labels[forloop.index0] }}
            </option>
          {% endfor %}
        </select>
      </div>
    </div>

    {% comment %} Productgrid {% endcomment %}
    <div class="coll-grid">
      {% paginate collection.products by section.settings.products_per_page %}

        {% if collection.products.size > 0 %}
          {% for product in collection.products %}
            <div class="prod-card">
              <a href="{{ product.url }}" class="prod-card__media-link">
                <div class="prod-card__media">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 700 }}"
                      alt="{{ product.featured_image.alt | escape | default: product.title }}"
                      width="700"
                      height="700"
                      loading="{% if forloop.index <= 4 %}eager{% else %}lazy{% endif %}"
                      class="prod-card__img"
                    >
                    {% if product.images.size > 1 %}
                      <img
                        src="{{ product.images[1] | image_url: width: 700 }}"
                        alt="{{ product.images[1].alt | escape | default: product.title }}"
                        width="700"
                        height="700"
                        loading="lazy"
                        class="prod-card__img prod-card__img--hover"
                      >
                    {% endif %}
                  {% else %}
                    <div class="prod-card__no-img">
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
                        <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/>
                      </svg>
                    </div>
                  {% endif %}

                  {% if product.tags contains 'nieuw' or product.tags contains 'Nieuw' %}
                    <span class="prod-card__badge prod-card__badge--new">Nieuw</span>
                  {% elsif product.tags contains 'populair' or product.tags contains 'Populair' %}
                    <span class="prod-card__badge prod-card__badge--pop">Populair</span>
                  {% elsif product.tags contains 'aanbieding' %}
                    <span class="prod-card__badge prod-card__badge--sale">Aanbieding</span>
                  {% endif %}

                  {% unless product.available %}
                    <div class="prod-card__sold-out">Uitverkocht</div>
                  {% endunless %}
                </div>
              </a>

              <div class="prod-card__body">
                {% if product.vendor != blank %}
                  <span class="prod-card__vendor">{{ product.vendor }}</span>
                {% endif %}

                <h2 class="prod-card__title">
                  <a href="{{ product.url }}">{{ product.title | escape }}</a>
                </h2>

                <div class="prod-card__price-row">
                  {% if product.compare_at_price > product.price %}
                    <span class="prod-card__price-compare">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                  <span class="prod-card__price">
                    {% if product.price_varies %}Vanaf {% endif %}
                    {{ product.price | money }}
                  </span>
                </div>

                {% if product.available %}
                  <a href="{{ product.url }}" class="btn-primary prod-card__btn">
                    Bekijk product
                  </a>
                {% else %}
                  <span class="prod-card__btn-disabled">Uitverkocht</span>
                {% endif %}
              </div>
            </div>
          {% endfor %}

        {% else %}
          <div class="coll-empty">
            <p>Er zijn momenteel geen producten in deze collectie.</p>
            <a href="{{ routes.root_url }}" class="btn-primary">Terug naar home</a>
          </div>
        {% endif %}

        {% comment %} Paginering {% endcomment %}
        {% if paginate.pages > 1 %}
          <div class="coll-pagination">
            {{ paginate | default_pagination }}
          </div>
        {% endif %}

      {% endpaginate %}
    </div>

  </div>
</div>

{% stylesheet %}
  .coll-page { padding: 40px 0 64px; }

  /* Breadcrumb */
  .coll-breadcrumb {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-bottom: 10px;
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  .coll-breadcrumb a { color: var(--color-muted); text-decoration: none; }
  .coll-breadcrumb a:hover { color: var(--color-gold); }

  /* Header */
  .coll-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 28px;
    gap: 16px;
    flex-wrap: wrap;
  }

  .coll-title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-foreground);
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .coll-desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.65;
    max-width: 560px;
  }

  .coll-count {
    font-size: 0.8rem;
    color: var(--color-muted);
    white-space: nowrap;
  }

  /* Toolbar */
  .coll-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .coll-filters {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    flex: 1;
  }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    padding: 7px 16px;
    border-radius: var(--radius-pill);
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    border: 1.5px solid var(--color-border);
    color: var(--color-muted);
    background: transparent;
    transition: all var(--transition);
    flex-shrink: 0;
  }

  .filter-pill:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .filter-pill--active {
    border-color: var(--color-accent);
    color: var(--color-foreground);
    background: var(--color-accent);
  }

  .coll-sort {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .coll-sort__label {
    font-size: 0.78rem;
    color: var(--color-muted);
  }

  .coll-sort__select {
    background: var(--color-bg-2);
    border: 1.5px solid var(--color-border);
    color: var(--color-foreground);
    padding: 7px 14px;
    border-radius: var(--radius-sm);
    font-size: 0.82rem;
    cursor: pointer;
    outline: none;
  }

  .coll-sort__select:focus {
    border-color: var(--color-gold);
  }

  /* Grid */
  .coll-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* Hover second image */
  .prod-card__img--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .prod-card:hover .prod-card__img--hover { opacity: 1; }
  .prod-card:hover .prod-card__img:first-of-type { opacity: 0; }

  .prod-card__sold-out {
    position: absolute;
    inset: 0;
    background: rgba(28,20,16,0.65);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground);
  }

  .prod-card__btn-disabled {
    display: block;
    width: 100%;
    text-align: center;
    padding: 10px;
    border-radius: var(--radius-pill);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-muted);
    border: 1.5px solid var(--color-border);
    margin-top: 10px;
    cursor: not-allowed;
  }

  /* Leeg */
  .coll-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 80px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .coll-empty p { color: var(--color-muted); font-size: 1rem; }

  /* Paginering */
  .coll-pagination {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 32px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  .coll-pagination a,
  .coll-pagination span {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    border: 1.5px solid var(--color-border);
    color: var(--color-foreground);
    transition: all var(--transition);
  }

  .coll-pagination a:hover { border-color: var(--color-gold); color: var(--color-gold); }
  .coll-pagination .current { background: var(--color-accent); border-color: var(--color-accent); color: #fff; }

  @media (max-width: 900px) {
    .coll-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .coll-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .coll-toolbar { flex-direction: column; align-items: flex-start; }
    .coll-sort { width: 100%; }
    .coll-sort__select { width: 100%; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collectiepagina",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Producten per pagina",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ]
}
{% endschema %}
