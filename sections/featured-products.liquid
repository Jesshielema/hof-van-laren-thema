{% comment %} Uitgelichte producten sectie — toont producten uit een gekozen collectie {% endcomment %}

{% assign featured = collections[section.settings.collection] %}

<div class="fp-section">
  <div class="container">
    <div class="fp-header">
      <div>
        <span class="sec-label">{{ section.settings.label | default: 'Nu populair' }}</span>
        <h2 class="sec-title">{{ section.settings.heading | default: 'Dit is er nu binnen' }}</h2>
        {% if section.settings.subtext != blank %}
          <p class="fp-sub">{{ section.settings.subtext }}</p>
        {% endif %}
      </div>
      {% if section.settings.cta_text != blank and section.settings.cta_url != blank %}
        <a href="{{ section.settings.cta_url }}" class="btn-outline fp-more">
          {{ section.settings.cta_text }} →
        </a>
      {% endif %}
    </div>

    <div class="fp-grid">
      {% if featured != blank and featured.products.size > 0 %}
        {% for product in featured.products limit: section.settings.products_count %}
          {% include 'product-card' with product: product %}
        {% else %}
          {%- comment -%}Inline product card als snippet niet bestaat{%- endcomment -%}
          {% for product in featured.products limit: section.settings.products_count %}
            <div class="prod-card">
              <a href="{{ product.url }}" class="prod-card__media-link">
                <div class="prod-card__media">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape | default: product.title }}"
                      width="600"
                      height="600"
                      loading="lazy"
                      class="prod-card__img"
                    >
                  {% else %}
                    <div class="prod-card__no-img">
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><path d="M12 2l3 6.5L22 9l-5 5 1.18 7L12 18l-6.18 3L7 16 2 11l7-0.5z"/></svg>
                    </div>
                  {% endif %}

                  {% if product.tags contains 'nieuw' or product.tags contains 'Nieuw' %}
                    <span class="prod-card__badge prod-card__badge--new">Nieuw</span>
                  {% elsif product.tags contains 'populair' or product.tags contains 'Populair' %}
                    <span class="prod-card__badge prod-card__badge--pop">Populair</span>
                  {% endif %}
                </div>
              </a>
              <div class="prod-card__body">
                {% if product.vendor != blank %}
                  <span class="prod-card__vendor">{{ product.vendor }}</span>
                {% endif %}
                <h3 class="prod-card__title">
                  <a href="{{ product.url }}">{{ product.title | escape }}</a>
                </h3>
                <div class="prod-card__price-row">
                  {% if product.compare_at_price > product.price %}
                    <span class="prod-card__price-compare">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                  <span class="prod-card__price">{{ product.price | money }}</span>
                </div>
                <a href="{{ product.url }}" class="btn-primary prod-card__btn">
                  Bekijk product
                </a>
              </div>
            </div>
          {% endfor %}
        {% endfor %}

      {% else %}
        {% comment %} Placeholder kaarten als er geen collectie is ingesteld {% endcomment %}
        {% for i in (1..6) %}
          <div class="prod-card prod-card--placeholder">
            <div class="prod-card__media">
              <div class="prod-card__no-img"></div>
            </div>
            <div class="prod-card__body">
              <div class="prod-card__ph-line prod-card__ph-line--sm"></div>
              <div class="prod-card__ph-line"></div>
              <div class="prod-card__ph-line prod-card__ph-line--price"></div>
              <div class="prod-card__ph-btn"></div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .fp-section { padding: 60px 0; }

  .fp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 32px;
    gap: 20px;
    flex-wrap: wrap;
  }

  .fp-sub {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin-top: 6px;
    line-height: 1.5;
  }

  .fp-more {
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  /* Product grid */
  .fp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* Product card */
  .prod-card {
    background: var(--color-bg-2);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: transform var(--transition), box-shadow var(--transition);
    display: flex;
    flex-direction: column;
  }

  .prod-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .prod-card__media {
    aspect-ratio: 1;
    overflow: hidden;
    position: relative;
    background: var(--color-bg-3);
  }

  .prod-card__media-link {
    display: block;
  }

  .prod-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .prod-card:hover .prod-card__img {
    transform: scale(1.05);
  }

  .prod-card__no-img {
    width: 100%;
    height: 100%;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
  }

  .prod-card__badge {
    position: absolute;
    top: 10px; left: 10px;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    z-index: 1;
  }

  .prod-card__badge--new { background: var(--color-accent); color: #fff; }
  .prod-card__badge--pop { background: var(--color-gold); color: var(--color-background); }

  .prod-card__body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .prod-card__vendor {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .prod-card__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-style: italic;
    font-weight: 400;
    color: var(--color-foreground);
    line-height: 1.3;
    flex: 1;
  }

  .prod-card__title a {
    text-decoration: none;
    color: inherit;
  }

  .prod-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-top: 4px;
  }

  .prod-card__price {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-gold);
  }

  .prod-card__price-compare {
    font-size: 0.82rem;
    color: var(--color-muted);
    text-decoration: line-through;
  }

  .prod-card__btn {
    margin-top: 10px;
    width: 100%;
    justify-content: center;
    padding: 10px 16px;
    font-size: 0.82rem;
  }

  /* Placeholder */
  .prod-card--placeholder { pointer-events: none; }
  .prod-card__ph-line {
    height: 12px;
    background: var(--color-bg-3);
    border-radius: 4px;
    animation: shimmer 1.5s infinite;
  }
  .prod-card__ph-line--sm { width: 40%; height: 8px; }
  .prod-card__ph-line--price { width: 30%; }
  .prod-card__ph-btn {
    height: 36px;
    background: var(--color-bg-3);
    border-radius: var(--radius-pill);
    margin-top: 6px;
    animation: shimmer 1.5s infinite 0.3s;
  }

  @keyframes shimmer {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.7; }
  }

  @media (max-width: 900px) {
    .fp-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }

  @media (max-width: 480px) {
    .fp-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .fp-header { flex-direction: column; align-items: flex-start; }
    .prod-card__btn { font-size: 0.75rem; padding: 9px 12px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Uitgelichte producten",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Nu populair"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titel",
      "default": "Dit is er nu binnen"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Ondertitel",
      "default": "Vers samengesteld door Marchien"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collectie"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Aantal producten",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Knop tekst",
      "default": "Bekijk alles"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Knop link"
    }
  ],
  "presets": [
    {
      "name": "Uitgelichte producten"
    }
  ]
}
{% endschema %}
