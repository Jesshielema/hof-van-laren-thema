{% comment %} Uitgelichte producten sectie — toont producten uit een gekozen collectie {% endcomment %}

{% assign featured = collections[section.settings.collection] %}

<div class="fp-section">
  <div class="container">
    <div class="fp-header">
      <div>
        <h2 class="sec-title">{{ section.settings.heading | default: 'Dit is er nu binnen' }}</h2>
        {% if section.settings.subtext != blank %}
          <p class="fp-sub">{{ section.settings.subtext }}</p>
        {% endif %}
      </div>
      {% if section.settings.cta_text != blank and section.settings.cta_url != blank %}
        <a href="{{ section.settings.cta_url }}" class="btn-outline fp-more">
          {{ section.settings.cta_text }} →
        </a>
      {% endif %}
    </div>

    <div class="fp-grid">
      {% if featured != blank and featured.products.size > 0 %}
        {% for product in featured.products limit: section.settings.products_count %}
          {% include 'product-card' with product: product %}
        {% else %}
          {%- comment -%}Inline product card als snippet niet bestaat{%- endcomment -%}
          {% for product in featured.products limit: section.settings.products_count %}
            <div class="prod-card">
              <a href="{{ product.url }}" class="prod-card__media-link">
                <div class="prod-card__media">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape | default: product.title }}"
                      width="600"
                      height="800"
                      loading="lazy"
                      class="prod-card__img"
                    >
                  {% else %}
                    <div class="prod-card__no-img">
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><path d="M12 2l3 6.5L22 9l-5 5 1.18 7L12 18l-6.18 3L7 16 2 11l7-0.5z"/></svg>
                    </div>
                  {% endif %}

                  {% if product.tags contains 'nieuw' or product.tags contains 'Nieuw' %}
                    <span class="prod-card__badge prod-card__badge--new">Nieuw</span>
                  {% elsif product.tags contains 'populair' or product.tags contains 'Populair' %}
                    <span class="prod-card__badge prod-card__badge--pop">Populair</span>
                  {% endif %}

                  <span class="prod-card__hover-btn">Bekijk product</span>
                </div>
              </a>
              <div class="prod-card__body">
                {% if product.vendor != blank %}
                  <span class="prod-card__vendor">{{ product.vendor }}</span>
                {% endif %}
                <h3 class="prod-card__title">
                  <a href="{{ product.url }}">{{ product.title | escape }}</a>
                </h3>
                <div class="prod-card__divider"></div>
                <div class="prod-card__price-row">
                  {% if product.compare_at_price > product.price %}
                    <span class="prod-card__price-compare">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                  <span class="prod-card__price">{{ product.price | money }}</span>
                </div>
                <a href="{{ product.url }}" class="prod-card__btn">
                  Bekijk product
                </a>
              </div>
            </div>
          {% endfor %}
        {% endfor %}

      {% else %}
        {% comment %} Placeholder kaarten als er geen collectie is ingesteld {% endcomment %}
        {% for i in (1..6) %}
          <div class="prod-card prod-card--placeholder">
            <div class="prod-card__media">
              <div class="prod-card__no-img"></div>
            </div>
            <div class="prod-card__body">
              <div class="prod-card__ph-line prod-card__ph-line--sm"></div>
              <div class="prod-card__ph-line"></div>
              <div class="prod-card__ph-line prod-card__ph-line--price"></div>
              <div class="prod-card__ph-btn"></div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .fp-section { padding: 72px 0; }

  .fp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    gap: 20px;
    flex-wrap: wrap;
  }

  .fp-sub {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin-top: 6px;
    line-height: 1.5;
  }

  .fp-more {
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  /* Product grid */
  .fp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* Product card */
  .prod-card {
    background: var(--color-bg-2);
    border-radius: 2px;
    overflow: hidden;
    border: none;
    box-shadow: 0 2px 16px rgba(28,20,16,0.10);
    transition: transform 0.38s cubic-bezier(0.22,1,0.36,1), box-shadow 0.38s cubic-bezier(0.22,1,0.36,1);
    display: flex;
    flex-direction: column;
  }

  .prod-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(28,20,16,0.18);
  }

  /* Image area */
  .prod-card__media {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    position: relative;
    background: var(--color-bg-3);
  }

  .prod-card__media-link {
    display: block;
    height: 100%;
  }

  .prod-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.22,1,0.36,1);
    display: block;
  }

  .prod-card:hover .prod-card__img {
    transform: scale(1.08);
  }

  /* Gradient overlay at bottom of image */
  .prod-card__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(28,20,16,0.45) 0%, transparent 50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.38s ease;
  }

  .prod-card:hover .prod-card__media::after {
    opacity: 1;
  }

  /* Quick-view hover button on image */
  .prod-card__hover-btn {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    opacity: 0;
    transition: opacity 0.32s ease, transform 0.32s cubic-bezier(0.22,1,0.36,1);
    white-space: nowrap;
    z-index: 2;
    background: rgba(245,238,228,0.95);
    color: var(--color-foreground);
    border: none;
    padding: 9px 22px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-block;
    pointer-events: none;
  }

  .prod-card:hover .prod-card__hover-btn {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .prod-card__no-img {
    width: 100%;
    height: 100%;
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
  }

  /* Badge */
  .prod-card__badge {
    position: absolute;
    top: 14px;
    left: 0;
    padding: 4px 12px 4px 10px;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    z-index: 1;
    border-radius: 0 2px 2px 0;
  }

  .prod-card__badge--new { background: var(--color-accent); color: #fff; }
  .prod-card__badge--pop { background: var(--color-gold); color: var(--color-background); }

  /* Card body */
  .prod-card__body {
    padding: 20px 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
    border-top: 1px solid var(--color-border);
  }

  .prod-card__vendor {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 7px;
  }

  .prod-card__title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-style: italic;
    font-weight: 400;
    color: var(--color-foreground);
    line-height: 1.35;
    flex: 1;
    margin-bottom: 12px;
  }

  .prod-card__title a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }

  .prod-card__title a:hover {
    color: var(--color-gold);
  }

  /* Gold divider */
  .prod-card__divider {
    width: 28px;
    height: 1px;
    background: var(--color-gold);
    margin-bottom: 12px;
    opacity: 0.6;
  }

  .prod-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 16px;
  }

  .prod-card__price {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-foreground);
    letter-spacing: 0.02em;
  }

  .prod-card__price-compare {
    font-size: 0.82rem;
    color: var(--color-muted);
    text-decoration: line-through;
  }

  /* Button — outlined elegant style */
  .prod-card__btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 11px 16px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 1px;
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease;
  }

  .prod-card__btn:hover {
    background: var(--color-foreground);
    border-color: var(--color-foreground);
    color: var(--color-background);
  }

  /* Placeholder */
  .prod-card--placeholder { pointer-events: none; }
  .prod-card__ph-line {
    height: 12px;
    background: var(--color-bg-3);
    border-radius: 2px;
    animation: shimmer 1.5s infinite;
  }
  .prod-card__ph-line--sm { width: 40%; height: 8px; }
  .prod-card__ph-line--price { width: 30%; }
  .prod-card__ph-btn {
    height: 38px;
    background: var(--color-bg-3);
    border-radius: 1px;
    margin-top: 10px;
    animation: shimmer 1.5s infinite 0.3s;
  }

  @keyframes shimmer {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.7; }
  }

  @media (max-width: 900px) {
    .fp-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  }

  @media (max-width: 480px) {
    .fp-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .fp-header { flex-direction: column; align-items: flex-start; }
    .prod-card__body { padding: 14px 14px 16px; }
    .prod-card__title { font-size: 1rem; }
    .prod-card__btn { font-size: 0.65rem; padding: 10px 12px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Uitgelichte producten",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Nu populair"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titel",
      "default": "Dit is er nu binnen"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Ondertitel",
      "default": "Vers samengesteld door Marchien"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collectie"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Aantal producten",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Knop tekst",
      "default": "Bekijk alles"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Knop link"
    }
  ],
  "presets": [
    {
      "name": "Uitgelichte producten"
    }
  ]
}
{% endschema %}
