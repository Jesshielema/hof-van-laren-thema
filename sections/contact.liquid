    {
      "type": "header",
      "content": "Google Maps"
    },
    {
      "type": "text",
      "id": "map_url",
      "label": "Google Maps embed-URL",
      "info": "Ga naar Google Maps → Delen → Kaart insluiten → kopieer de src-URL uit de iframe-code"
    }
  ],
  "presets": [{ "name": "Contact" }]
}
