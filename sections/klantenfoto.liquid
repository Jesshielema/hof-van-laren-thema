{%- render 'section-typo' -%}
<section class="klanten full-width"{%- if s_style != blank %} style="{{ s_style }}"{%- endif -%}>
  <div class="klanten__inner">

    <div class="klanten__header">
      <div>
        <h2 class="klanten__title">
          {{ section.settings.title | default: "Foto's van tevreden" | escape }}
          <strong>{{ section.settings.title_bold | default: 'klanten' | escape }}</strong>
        </h2>
        {% if section.settings.subtitle != blank %}
          <p class="klanten__subtitle">{{ section.settings.subtitle | escape }}</p>
        {% endif %}
      </div>
    </div>

    <div class="klanten__mosaic">
      {% for i in (1..7) %}
        {% assign img_key = 'foto_' | append: i %}
        {% assign img_val = section.settings[img_key] %}
        {% if img_val != blank %}
          <div class="klanten__foto klanten__foto--{{ i }}">
            <img
              src="{{ img_val | image_url: width: 800 }}"
              alt="{{ img_val.alt | default: 'Klantfoto' | escape }}"
              width="800"
              loading="lazy"
              class="klanten__img"
            >
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.cta_url != blank %}
      <div class="klanten__cta-wrap">
        <a href="{{ section.settings.cta_url }}" class="klanten__cta">
          {{ section.settings.cta_text | default: 'Bekijk meer' | escape }} →
        </a>
      </div>
    {% endif %}

  </div>
</section>

{% stylesheet %}
  .klanten {
    background-color: var(--color-background);
    padding: 5rem 0;
  }

  .klanten__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .klanten__title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    font-weight: 300;
    font-style: italic;
    color: var(--color-foreground);
    margin: 0 0 0.4rem;
    line-height: 1.1;
  }

  .klanten__title strong {
    font-weight: 700;
    font-style: normal;
  }

  .klanten__subtitle {
    font-size: 0.875rem;
    font-weight: 300;
    color: var(--color-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* Mosaic grid */
  .klanten__mosaic {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto;
    gap: 0.5rem;
  }

  .klanten__foto {
    overflow: hidden;
    border-radius: var(--radius-sm);
    background: var(--color-bg-2);
  }

  /* Standaard: vierkant */
  .klanten__foto { aspect-ratio: 1; }

  /* Foto 1 — groot, links bovenaan (2 rijen hoog) */
  .klanten__foto--1 {
    grid-column: 1;
    grid-row: 1 / 3;
    aspect-ratio: auto;
  }

  /* Foto 7 — groot, rechts onderaan (2 rijen hoog) */
  .klanten__foto--7 {
    grid-column: 3;
    grid-row: 3 / 5;
    aspect-ratio: auto;
  }

  .klanten__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .klanten__foto:hover .klanten__img {
    transform: scale(1.04);
  }

  .klanten__cta-wrap {
    display: flex;
    justify-content: center;
  }

  .klanten__cta {
    display: inline-block;
    color: var(--color-foreground);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    border: 1px solid rgba(28,20,16,0.3);
    padding: 0.6rem 1.5rem;
    border-radius: 3px;
    transition: border-color 0.2s, background-color 0.2s;
  }

  .klanten__cta:hover {
    border-color: var(--color-foreground);
    background-color: rgba(28,20,16,0.04);
  }

  @media (max-width: 768px) {
    .klanten__mosaic {
      grid-template-columns: repeat(2, 1fr);
    }

    .klanten__foto--1 {
      grid-column: 1;
      grid-row: 1 / 3;
    }

    .klanten__foto--7 {
      grid-column: 2;
      grid-row: auto;
      aspect-ratio: 1;
    }

    .klanten {
      padding: 3.5rem 0;
    }
  }
{% endstylesheet %}

