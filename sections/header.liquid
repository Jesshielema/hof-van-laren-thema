<header class="site-header">
  <div class="header__bar">

    <button
      class="header__hamburger"
      aria-label="{{ 'general.accessibility.open_menu' | t }}"
      aria-expanded="false"
      data-toggle="mobile-nav"
    >
      <svg width="26" height="18" viewBox="0 0 26 18" fill="none" aria-hidden="true">
        <rect width="26" height="2.5" rx="1.25" fill="currentColor"/>
        <rect y="7.5" width="26" height="2.5" rx="1.25" fill="currentColor"/>
        <rect y="15" width="26" height="2.5" rx="1.25" fill="currentColor"/>
      </svg>
    </button>

    <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name }}">
      {% if section.settings.logo != blank %}
        <img
          src="{{ section.settings.logo | image_url: width: 180 }}"
          alt="{{ shop.name }}"
          width="180"
          height="90"
          loading="eager"
          class="header__logo-img"
        >
      {% else %}
        <span class="header__logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>

    <div class="header__icons">
      <a href="{{ routes.search_url }}" class="header__icon" aria-label="{{ 'general.search.title' | t }}">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <circle cx="9.5" cy="9.5" r="8.5" stroke="currentColor" stroke-width="2"/>
          <line x1="15.8" y1="16.2" x2="21" y2="21.4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </a>
      <a href="{{ routes.cart_url }}" class="header__icon header__cart-icon" aria-label="{{ 'general.cart.title' | t }}">
        {% if cart.item_count > 0 %}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <path d="M1 1.5h3.2l2.6 11.8a2 2 0 0 0 2 1.7h8.8a2 2 0 0 0 1.96-1.6l1.44-7.4H5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="19.5" r="1.5" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="17" cy="19.5" r="1.5" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </a>
    </div>

  </div>

  <nav class="header__nav" aria-label="{{ 'general.accessibility.main_nav' | t }}">
    {% for link in section.settings.menu.links %}
      <a
        href="{{ link.url }}"
        class="header__nav-link{% if link.active %} header__nav-link--active{% endif %}"
        {% if link.active %}aria-current="page"{% endif %}
      >{{ link.title | escape }}</a>
    {% endfor %}
  </nav>
</header>

<div class="drawer-overlay" id="drawer-overlay" aria-hidden="true"></div>

<aside class="drawer" id="mobile-nav" aria-hidden="true" aria-label="Winkelinformatie">
  <div class="drawer__inner">

    <button class="drawer__close" data-toggle="mobile-nav" aria-label="Menu sluiten">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <line x1="2" y1="2" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="18" y1="2" x2="2" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="drawer__brand">
      <a href="{{ routes.root_url }}" class="drawer__brand-link" data-toggle="mobile-nav">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}" width="160" height="80" loading="lazy" class="drawer__brand-img">
        {% else %}
          <span class="drawer__brand-name">{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <div class="drawer__section-title">Winkelinformatie</div>

    <nav class="drawer__nav">
      <a href="{{ section.settings.drawer_url_1 | default: '/pages/over-hof-van-laren' }}" class="drawer__link" data-toggle="mobile-nav" style="--i:0">
        Over Hof van Laren
      </a>
      <a href="{{ section.settings.drawer_url_2 | default: '/pages/over-marchien' }}" class="drawer__link" data-toggle="mobile-nav" style="--i:1">
        Ontmoet Marchien
      </a>
      <a href="{{ section.settings.drawer_url_3 | default: '#winkel' }}" class="drawer__link" data-toggle="mobile-nav" style="--i:2">
        Bezoek de winkel
      </a>
      <a href="{{ section.settings.drawer_url_4 | default: '#winkel' }}" class="drawer__link" data-toggle="mobile-nav" style="--i:3">
        Openingstijden
      </a>
      <a href="{{ section.settings.drawer_url_5 | default: '/pages/contact' }}" class="drawer__link" data-toggle="mobile-nav" style="--i:4">
        Contact
      </a>
      <a href="{{ section.settings.drawer_url_6 | default: 'https://instagram.com' }}" class="drawer__link drawer__link--instagram" target="_blank" rel="noopener" style="--i:5">
        Instagram
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="drawer__link-icon">
          <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
        </svg>
      </a>
    </nav>

    <div class="drawer__footer">
      <p class="drawer__footer-address">Stationsweg 2, Zuidlaren</p>
      <a href="tel:{{ section.settings.phone | default: '0640356687' | remove: '-' | remove: ' ' }}" class="drawer__footer-phone">
        {{ section.settings.phone | default: '06-40356687' }}
      </a>
    </div>

  </div>
</aside>

{% stylesheet %}
  .site-header {
    background-color: var(--color-background);
    color: var(--color-foreground);
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  /* Top bar: hamburger | logo | icons */
  .header__bar {
    display: grid;
    grid-template-columns: 48px 1fr 72px;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.75rem 2rem;
    gap: 1rem;
  }

  /* Hamburger — altijd zichtbaar (ook desktop) */
  .header__hamburger {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-foreground);
    padding: 0;
    display: flex;
    align-items: center;
    justify-self: start;
    line-height: 0;
  }

  /* Logo gecentreerd */
  .header__logo {
    display: flex;
    justify-content: center;
    text-decoration: none;
    filter: drop-shadow(0 4px 10px rgba(0,0,0,0.25));
  }

  .header__logo-img {
    display: block;
    height: 90px;
    width: auto;
    max-width: 180px;
    object-fit: contain;
  }

  .header__logo-text {
    font-size: 1.6rem;
    font-weight: 700;
    font-style: italic;
    color: var(--color-foreground);
    letter-spacing: 0.02em;
    line-height: 1;
    white-space: nowrap;
  }

  /* Iconen rechts */
  .header__icons {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    color: var(--color-foreground);
  }

  .header__icon {
    color: inherit;
    text-decoration: none;
    display: flex;
    align-items: center;
    position: relative;
    opacity: 0.9;
    transition: opacity 0.2s;
  }

  .header__icon:hover {
    opacity: 1;
  }

  .header__cart-count {
    position: absolute;
    top: -0.45rem;
    right: -0.45rem;
    background-color: var(--color-accent);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* Desktop navigatie — gecentreerd onder logo */
  .header__nav {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: 0.5rem 2rem 0.85rem;
    max-width: 1280px;
    margin: 0 auto;
  }

  .header__nav-link {
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.875rem;
    font-weight: 300;
    letter-spacing: 0.03em;
    opacity: 0.9;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .header__nav-link:hover {
    opacity: 1;
  }

  .header__nav-link--active {
    opacity: 1;
    font-weight: 500;
    border-bottom: 1.5px solid var(--color-foreground);
    padding-bottom: 1px;
  }

  /* Overlay */
  .drawer-overlay {
    position: fixed;
    inset: 0;
    background: rgba(28, 20, 16, 0.45);
    z-index: 199;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .drawer-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* Drawer */
  .drawer {
    position: fixed;
    top: 0;
    left: 0;
    height: 100dvh;
    width: min(340px, 88vw);
    background: var(--color-background);
    z-index: 200;
    transform: translateX(-100%);
    transition: transform 0.42s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    box-shadow: 4px 0 32px rgba(28, 20, 16, 0.18);
  }

  .drawer.is-open {
    transform: translateX(0);
  }

  .drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem 2rem 2rem;
    overflow-y: auto;
    gap: 0;
  }

  /* Sluitknop */
  .drawer__close {
    align-self: flex-end;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-foreground);
    padding: 4px;
    opacity: 0.6;
    transition: opacity 0.2s;
    margin-bottom: 1.5rem;
    line-height: 0;
  }

  .drawer__close:hover { opacity: 1; }

  /* Merk */
  .drawer__brand {
    margin-bottom: 2.5rem;
  }

  .drawer__brand-link {
    display: inline-block;
    text-decoration: none;
  }

  .drawer__brand-img {
    height: 56px;
    width: auto;
    object-fit: contain;
  }

  .drawer__brand-name {
    font-family: 'skeena', Georgia, serif;
    font-size: 1.4rem;
    font-style: italic;
    font-weight: 700;
    color: var(--color-foreground);
  }

  /* Sectietitel */
  .drawer__section-title {
    font-family: 'Archivo', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  /* Nav links */
  .drawer__nav {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .drawer__link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    font-family: 'skeena', Georgia, serif;
    font-size: 1.4rem;
    font-style: italic;
    font-weight: 400;
    color: var(--color-foreground);
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: color 0.22s, padding-left 0.22s;
    opacity: 0;
    transform: translateX(-12px);
  }

  .drawer__link:last-child { border-bottom: none; }

  .drawer__link:hover {
    color: var(--color-gold);
    padding-left: 4px;
  }

  .drawer__link--instagram { color: var(--color-muted); }
  .drawer__link--instagram:hover { color: var(--color-foreground); }

  .drawer__link-icon { flex-shrink: 0; opacity: 0.7; }

  /* Staggered link animatie — alleen actief als drawer open is */
  .drawer.is-open .drawer__link {
    animation: drawerLinkIn 0.38s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(0.18s + var(--i) * 0.055s);
  }

  @keyframes drawerLinkIn {
    to { opacity: 1; transform: translateX(0); }
  }

  /* Footer */
  .drawer__footer {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .drawer__footer-address {
    font-size: 0.78rem;
    color: var(--color-muted);
  }

  .drawer__footer-phone {
    font-size: 0.88rem;
    color: var(--color-foreground);
    text-decoration: none;
    font-weight: 500;
  }

  .drawer__footer-phone:hover { color: var(--color-gold); }

  /* Hamburger animatie → X */
  .header__hamburger svg rect {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.2s ease;
    transform-origin: center;
  }

  .header__hamburger.is-open svg rect:nth-child(1) {
    transform: translateY(7.5px) rotate(45deg);
  }

  .header__hamburger.is-open svg rect:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .header__hamburger.is-open svg rect:nth-child(3) {
    transform: translateY(-7.5px) rotate(-45deg);
  }

  /* Desktop nav verbergen op mobiel */
  @media (max-width: 768px) {
    .header__logo-img { height: 60px; }
    .header__nav { display: none; }
    .header__bar { padding: 0.6rem 1.25rem; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var drawer   = document.getElementById('mobile-nav');
    var overlay  = document.getElementById('drawer-overlay');
    var hamburger = document.querySelector('.header__hamburger');
    if (!drawer || !overlay || !hamburger) return;

    function openDrawer() {
      drawer.classList.add('is-open');
      overlay.classList.add('is-open');
      hamburger.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      hamburger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.remove('is-open');
      overlay.classList.remove('is-open');
      hamburger.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    hamburger.addEventListener('click', function () {
      drawer.classList.contains('is-open') ? closeDrawer() : openDrawer();
    });

    overlay.addEventListener('click', closeDrawer);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeDrawer();
    });

    document.querySelectorAll('.drawer__close').forEach(function (btn) {
      btn.addEventListener('click', closeDrawer);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigatie (desktop)",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Zijmenu links"
    },
    {
      "type": "url",
      "id": "drawer_url_1",
      "label": "Over Hof van Laren — link"
    },
    {
      "type": "url",
      "id": "drawer_url_2",
      "label": "Ontmoet Marchien — link"
    },
    {
      "type": "url",
      "id": "drawer_url_3",
      "label": "Bezoek de winkel — link"
    },
    {
      "type": "url",
      "id": "drawer_url_4",
      "label": "Openingstijden — link"
    },
    {
      "type": "url",
      "id": "drawer_url_5",
      "label": "Contact — link"
    },
    {
      "type": "url",
      "id": "drawer_url_6",
      "label": "Instagram — link"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Telefoonnummer",
      "default": "06-40356687"
    }
  ]
}
{% endschema %}
