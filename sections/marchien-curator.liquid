{% comment %}
  Marchien als curator sectie
  ─────────────────────────────────────────────────────────
  FIGMA → SHOPIFY VOORBEELD

  Hoe teksten aanpasbaar worden:
    Figma tekst "Persoonlijk advies"  →  {{ section.settings.label }}
    Figma tekst "Koptitel"            →  {{ section.settings.heading }}
    Figma afbeelding                  →  {{ section.settings.image }}

  CSS schrijf je precies zoals in Figma:
    Figma: font-size 48, color #F5EEE4  →  CSS: font-size: 3rem; color: #f5eee4
    Figma: gap 64px                     →  CSS: gap: 4rem
    Figma: border-radius 8              →  CSS: border-radius: 8px
{% endcomment %}

<section class="mc-section full-width">
  <div class="mc-inner">

    {% comment %} — MEDIA KANT (foto) — {% endcomment %}
    <div class="mc-media {% if section.settings.image_position == 'right' %}mc-media--right{% endif %}">
      {% if section.settings.image != blank %}
        <div class="mc-img-wrap">
          <img
            src="{{ section.settings.image | image_url: width: 700 }}"
            alt="{{ section.settings.image.alt | default: 'Marchien' | escape }}"
            width="700"
            loading="lazy"
            class="mc-img"
          >
        </div>
      {% else %}
        <div class="mc-img-placeholder">
          {{ 'person-1' | placeholder_svg_tag: 'mc-img-placeholder__svg' }}
        </div>
      {% endif %}

      {% comment %} Optioneel: een klein accent-label op de foto {% endcomment %}
      {% if section.settings.image_label != blank %}
        <div class="mc-img-label">{{ section.settings.image_label }}</div>
      {% endif %}
    </div>

    {% comment %} — CONTENT KANT (tekst) — {% endcomment %}
    <div class="mc-content">

      {% comment %} Klein label bovenaan {% endcomment %}
      {% if section.settings.label != blank %}
        <span class="mc-label">{{ section.settings.label }}</span>
      {% endif %}

      {% comment %} Goudlijn onder label {% endcomment %}
      <div class="mc-rule" aria-hidden="true"></div>

      {% comment %} Grote koptitel {% endcomment %}
      <h2 class="mc-heading">{{ section.settings.heading | default: 'Geselecteerd met oog voor sfeer en kwaliteit' }}</h2>

      {% comment %} Lopende tekst — rich text zodat Marchien zelf bold/italic kan gebruiken {% endcomment %}
      {% if section.settings.body != blank %}
        <div class="mc-body">{{ section.settings.body }}</div>
      {% endif %}

      {% comment %} Knop {% endcomment %}
      {% if section.settings.cta_url != blank %}
        <a href="{{ section.settings.cta_url }}" class="mc-btn">
          {{ section.settings.cta_text | default: "Ontdek Marchien's favorieten" }} →
        </a>
      {% endif %}

    </div>
  </div>
</section>


{% comment %}
  ─────────────────────────────────────────────────────────
  CSS — schrijf dit precies zoals je Figma-maten zijn
  ─────────────────────────────────────────────────────────
{% endcomment %}
{% stylesheet %}

  /* Sectie wrapper */
  .mc-section {
    background-color: var(--color-background);  /* donker thema */
    padding: 80px 0;
  }

  /* Binnenste container — altijd max 1280px gecentreerd */
  .mc-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;

    /* Twee kolommen naast elkaar */
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  /* ── MEDIA KANT ── */
  .mc-media {
    position: relative;
  }

  /* Foto rechts als setting dat aangeeft */
  .mc-media--right {
    order: 2;
  }

  .mc-img-wrap {
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 3 / 4;   /* portretverhouding */
  }

  .mc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .mc-img-wrap:hover .mc-img {
    transform: scale(1.04);
  }

  .mc-img-placeholder {
    aspect-ratio: 3 / 4;
    background-color: var(--color-bg-2);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mc-img-placeholder__svg {
    width: 80px;
    opacity: 0.2;
  }

  /* Klein label op de foto */
  .mc-img-label {
    position: absolute;
    bottom: 20px;
    left: 20px;
    background-color: var(--color-gold);
    color: var(--color-background);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 4px;
  }

  /* ── CONTENT KANT ── */
  .mc-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mc-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    display: block;
    margin-bottom: 10px;
  }

  /* Goudlijn — past bij jouw Figma-stijl */
  .mc-rule {
    width: 50px;
    height: 1px;
    background-color: var(--color-gold);
    margin-bottom: 24px;
  }

  /* Koptitel — gebruik je Skeena/heading font */
  .mc-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-foreground);
    line-height: 1.15;
    margin-bottom: 24px;
    letter-spacing: -0.01em;
  }

  /* Lopende tekst */
  .mc-body {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(245, 238, 228, 0.75);
    margin-bottom: 32px;
  }

  .mc-body p { margin-bottom: 12px; }
  .mc-body strong { font-weight: 600; color: var(--color-foreground); }

  /* Knop — gebruik je bestaande stijl */
  .mc-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: transparent;
    color: var(--color-foreground);
    border: 1.5px solid rgba(245, 238, 228, 0.35);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 12px 24px;
    border-radius: 5px;
    transition: border-color 0.2s, background-color 0.2s;
    width: fit-content;
  }

  .mc-btn:hover {
    border-color: var(--color-foreground);
    background-color: rgba(245, 238, 228, 0.06);
  }

  /* ── MOBIEL ── */
  @media (max-width: 768px) {
    .mc-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    /* Op mobiel altijd foto boven tekst */
    .mc-media--right {
      order: 0;
    }
  }

{% endstylesheet %}


{% comment %}
  ─────────────────────────────────────────────────────────
  SCHEMA — dit verschijnt in de Theme Editor
  Elke setting hier = één invulveld voor de klant
  ─────────────────────────────────────────────────────────
{% endcomment %}
{% schema %}
{
  "name": "Marchien als curator",
  "settings": [
    {
      "type": "header",
      "content": "Afbeelding"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Foto"
    },
    {
      "type": "text",
      "id": "image_label",
      "label": "Label op foto (optioneel)",
      "default": "Elke dag vers"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Foto positie",
      "options": [
        { "value": "left",  "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Teksten"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Klein label",
      "default": "Persoonlijk advies"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Koptitel",
      "default": "Geselecteerd met oog voor sfeer en kwaliteit"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Tekst",
      "default": "<p>Marchien luistert naar jouw verhaal en maakt een arrangement dat daar perfect bij past. Niet van de plank, maar van het hart — met aandacht voor kleur, sfeer en de ruimte waar het in komt.</p><p>Kom langs in de winkel of bestel online. Marchien kiest het mooiste voor je uit.</p>"
    },
    {
      "type": "header",
      "content": "Knop"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Knoptekst",
      "default": "Ontdek Marchiens favorieten"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Knoplink"
    }
  ],
  "presets": [
    {
      "name": "Marchien als curator"
    }
  ]
}
{% endschema %}
