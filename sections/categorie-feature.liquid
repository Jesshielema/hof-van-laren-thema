{%- render 'section-typo' -%}
<section class="catfeat full-width"{%- if s_style != blank %} style="{{ s_style }}"{%- endif -%}>
  <div class="catfeat__inner{% if section.settings.image_side == 'left' %} catfeat__inner--img-left{% endif %}">

    <div class="catfeat__text">
      <h2 class="catfeat__heading">{{ section.settings.heading | default: 'Categorie' }}</h2>
      {% if section.settings.body != blank %}
        <div class="catfeat__body">{{ section.settings.body }}</div>
      {% endif %}
      {% if section.settings.cta_text != blank %}
        {% assign cta_href = section.settings.cta_url | default: '/collections/all' %}
        <a href="{{ cta_href }}" class="catfeat__btn">
          {{ section.settings.cta_text | escape }} →
        </a>
      {% endif %}
    </div>

    <div class="catfeat__image-wrap">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
          width="900"
          loading="lazy"
          class="catfeat__image"
        >
      {% else %}
        {{ 'collection-1' | placeholder_svg_tag: 'catfeat__image catfeat__image--placeholder' }}
      {% endif %}
    </div>

  </div>
</section>

{% stylesheet %}
  .catfeat {
    background-color: var(--color-gold);
    overflow: hidden;
  }

  .catfeat__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 460px;
  }

  /* Standaard: tekst links, foto rechts */
  .catfeat__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 3.5rem;
    gap: 1.25rem;
  }

  .catfeat__image-wrap {
    overflow: hidden;
  }

  /* Foto links variant */
  .catfeat__inner--img-left .catfeat__image-wrap {
    order: -1;
  }

  .catfeat__heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-background);
    line-height: 1.05;
    margin: 0;
  }

  .catfeat__body {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(245,238,228,0.85);
    max-width: 420px;
  }

  .catfeat__body strong {
    font-weight: 600;
    color: var(--color-background);
  }

  .catfeat__body p { margin: 0; }

  .catfeat__btn {
    display: inline-block;
    color: var(--color-background);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    border: 1px solid rgba(245,238,228,0.5);
    padding: 0.5rem 1.1rem;
    border-radius: 3px;
    transition: border-color 0.2s, background-color 0.2s;
    width: fit-content;
  }

  .catfeat__btn:hover {
    border-color: var(--color-background);
    background-color: rgba(245,238,228,0.12);
  }

  .catfeat__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .catfeat__image--placeholder {
    width: 100%;
    height: 100%;
    opacity: 0.2;
    background: var(--color-bg-2);
  }

  @media (max-width: 768px) {
    .catfeat__inner {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .catfeat__image-wrap {
      height: 280px;
      order: -1;
    }

    .catfeat__inner--img-left .catfeat__image-wrap {
      order: -1;
    }

    .catfeat__text {
      padding: 2.5rem 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Categorie feature",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titel",
      "default": "Echeveria"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Tekst",
      "default": "<p>De Echeveria is één van de meest geliefde <strong>vetplanten</strong> en dat is niet zonder reden. Met zijn perfecte rozatvorm en <strong>prachtige kleuren</strong> — van blauwgrijs tot zachtroze en paars — lijkt het bijna alsof deze plant met de hand is gevormd.</p>"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Knoptekst",
      "default": "Bekijk alle vetplanten"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Knoplink"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding"
    },
    {
      "type": "select",
      "id": "image_side",
      "label": "Foto positie",
      "options": [
        { "value": "right", "label": "Rechts (tekst links)" },
        { "value": "left",  "label": "Links (tekst rechts)" }
      ],
      "default": "right"
    },
    { "type": "header", "content": "Typografie" },
    { "type": "select", "id": "heading_font", "label": "Koppen — lettertype", "options": [{ "value": "inherit", "label": "— Standaard thema —" }, { "value": "'skeena', 'Cormorant Garamond', Georgia, serif", "label": "Skeena" }, { "value": "'Archivo', sans-serif", "label": "Archivo" }], "default": "inherit" },
    { "type": "select", "id": "heading_weight", "label": "Koppen — dikte", "options": [{ "value": "inherit", "label": "— Standaard —" }, { "value": "100", "label": "Thin (100)" }, { "value": "200", "label": "Extra Light (200)" }, { "value": "300", "label": "Light (300)" }, { "value": "400", "label": "Regular (400)" }, { "value": "500", "label": "Medium (500)" }, { "value": "600", "label": "SemiBold (600)" }, { "value": "700", "label": "Bold (700)" }, { "value": "800", "label": "Extra Bold (800)" }], "default": "inherit" },
    { "type": "select", "id": "heading_style", "label": "Koppen — stijl", "options": [{ "value": "inherit", "label": "— Standaard —" }, { "value": "normal", "label": "Normaal" }, { "value": "italic", "label": "Cursief" }], "default": "inherit" },
    { "type": "color", "id": "heading_color", "label": "Koppen — kleur" },
    { "type": "select", "id": "body_font", "label": "Tekst — lettertype", "options": [{ "value": "inherit", "label": "— Standaard thema —" }, { "value": "'Archivo', sans-serif", "label": "Archivo" }, { "value": "'skeena', 'Cormorant Garamond', Georgia, serif", "label": "Skeena" }], "default": "inherit" },
    { "type": "select", "id": "body_weight", "label": "Tekst — dikte", "options": [{ "value": "inherit", "label": "— Standaard —" }, { "value": "100", "label": "Thin (100)" }, { "value": "200", "label": "Extra Light (200)" }, { "value": "300", "label": "Light (300)" }, { "value": "400", "label": "Regular (400)" }, { "value": "500", "label": "Medium (500)" }, { "value": "600", "label": "SemiBold (600)" }, { "value": "700", "label": "Bold (700)" }], "default": "inherit" },
    { "type": "color", "id": "body_color", "label": "Tekst — kleur" }
  ],
  "presets": [
    {
      "name": "Categorie feature"
    }
  ]
}
{% endschema %}
