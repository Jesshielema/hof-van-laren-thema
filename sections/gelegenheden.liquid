{%- render 'section-typo' -%}
<section class="gel-section"{%- if s_style != blank %} style="{{ s_style }}"{%- endif -%}>
  <div class="gel-inner">

    <h2 class="gel-title">Kies uw gelegenheid</h2>

    <nav class="gel-nav" aria-label="Gelegenheden">
      {% for i in (1..6) %}
        {% liquid
          assign text_key = 'occasion_' | append: i | append: '_text'
          assign url_key  = 'occasion_' | append: i | append: '_url'
          assign text_val = section.settings[text_key]
          assign url_val  = section.settings[url_key] | default: '/collections/all'
        %}
        {% if text_val != blank %}
          {% unless forloop.first %}<span class="gel-nav__dot" aria-hidden="true">·</span>{% endunless %}
          <a href="{{ url_val }}" class="gel-nav__link">{{ text_val | escape }}</a>
        {% endif %}
      {% endfor %}
    </nav>

    <div class="gel-images">
      {% for i in (1..3) %}
        {% liquid
          assign img_key = 'collection_image_' | append: i
          assign url_key = 'collection_url_' | append: i
          assign img_val = section.settings[img_key]
          assign url_val = section.settings[url_key] | default: '/collections/all'
        %}
        <a href="{{ url_val }}" class="gel-images__link">
          {% if img_val != blank %}
            <img
              src="{{ img_val | image_url: width: 600 }}"
              alt="{{ img_val.alt | escape }}"
              width="600"
              height="480"
              loading="lazy"
              class="gel-images__img"
            >
          {% else %}
            {{ 'collection-' | append: i | placeholder_svg_tag: 'gel-images__img gel-images__img--placeholder' }}
          {% endif %}
        </a>
      {% endfor %}
    </div>

  </div>
</section>

{% stylesheet %}
  .gel-section {
    background-color: var(--color-background);
    padding: 2.5rem 0 3rem;
  }

  .gel-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .gel-title {
    font-family: 'skeena', 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-foreground);
    text-align: center;
    margin: 0;
    line-height: 1.15;
  }

  /* Gelegenheden-balk */
  .gel-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.25rem 0.1rem;
  }

  .gel-nav__link {
    color: var(--color-foreground);
    text-decoration: none;
    font-size: 1.15rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.5rem;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .gel-nav__link:hover {
    opacity: 1;
  }

  .gel-nav__dot {
    color: var(--color-foreground);
    opacity: 0.35;
    font-size: 1.1rem;
    line-height: 1;
    padding: 0 0.15rem;
  }

  /* Drie foto's */
  .gel-images {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .gel-images__link {
    display: block;
    overflow: hidden;
    border-radius: 3px;
    text-decoration: none;
  }

  .gel-images__img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
    border-radius: 3px;
    transition: transform 0.45s ease;
  }

  .gel-images__link:hover .gel-images__img {
    transform: scale(1.04);
  }

  .gel-images__img--placeholder {
    background-color: rgba(255,255,255,0.15);
    height: 420px;
  }

  @media (max-width: 900px) {
    .gel-inner {
      padding: 0;
      gap: 1.5rem;
    }

    .gel-nav {
      padding: 0 1.25rem;
      gap: 0.1rem 0;
    }

    .gel-nav__link {
      font-size: 0.9rem;
      padding: 0.3rem 0.4rem;
    }

    /* Horizontal scroll-snap slider */
    .gel-images {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 0.75rem;
      padding: 0 1.25rem 1.25rem;
      scrollbar-width: none;
      grid-template-columns: unset;
    }

    .gel-images::-webkit-scrollbar {
      display: none;
    }

    .gel-images__link {
      flex: 0 0 78%;
      scroll-snap-align: start;
      border-radius: 4px;
    }

    .gel-images__img,
    .gel-images__img--placeholder {
      height: 300px;
      border-radius: 4px;
    }
  }

  @media (max-width: 480px) {
    .gel-images__link {
      flex: 0 0 85%;
    }

    .gel-images__img,
    .gel-images__img--placeholder {
      height: 260px;
    }
  }
{% endstylesheet %}

