{%- render 'section-typo' -%}
<section class="despots full-width"{%- if s_style != blank %} style="{{ s_style }}"{%- endif -%}>
  <div class="despots__inner">
    <div class="despots__image-wrap">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 400 }}"
          alt="{{ section.settings.image.alt | escape }}"
          width="343"
          height="423"
          loading="lazy"
          class="despots__image"
        >
      {% else %}
        {{ 'product-2' | placeholder_svg_tag: 'despots__image placeholder' }}
      {% endif %}
    </div>

    <div class="despots__content">
      <h2 class="despots__heading">{{ section.settings.heading | default: 'Des Pots' | escape }}</h2>
      <div class="despots__description">
        {{ section.settings.description | default: 'Deze potten zijn geen vazen. Dit zijn karakters. Des Pots maakt stukken die een kamer direct veranderen vol kleur, vol leven, vol persoonlijkheid. Of je er bloemen in zet of niet: ze staan prachtig op zichzelf.' }}
      </div>
      {% assign cta_href = section.settings.cta_url | default: '/collections/des-pots' %}
      <a href="{{ cta_href }}" class="despots__cta">
        {{ section.settings.cta_text | default: 'Bekijk collectie' | escape }} →
      </a>
    </div>
  </div>
</section>

{% stylesheet %}
  .despots {
    background-color: var(--color-gold);
    color: var(--color-background);
    overflow: hidden;
  }

  .despots__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 2rem;
    display: flex;
    align-items: center;
    gap: 4rem;
    min-height: 541px;
  }

  .despots__image-wrap {
    flex-shrink: 0;
    width: 343px;
    height: 423px;
    overflow: hidden;
  }

  .despots__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .despots__image.placeholder {
    background-color: rgba(0,0,0,0.1);
    opacity: 0.6;
    height: 423px;
    width: 343px;
  }

  .despots__content {
    flex: 1;
    max-width: 540px;
  }

  .despots__label {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-background);
    letter-spacing: 0.1em;
    margin: 0 0 0.25rem;
  }

  .despots__label-line {
    width: 63px;
    height: 1px;
    background-color: var(--color-background);
    margin-bottom: 1.25rem;
  }

  .despots__heading {
    font-family: 'Skeena', Georgia, serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 700;
    font-style: normal;
    color: var(--color-background);
    margin: 0 0 1.5rem;
    line-height: 1;
  }

  .despots__description {
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: 2rem;
    color: var(--color-background);
  }

  .despots__description strong {
    font-weight: 700;
  }

  .despots__cta {
    display: inline-block;
    color: var(--color-background);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    border: 2px solid var(--color-background);
    padding: 0.55rem 1.25rem;
    transition: background-color 0.2s, color 0.2s;
  }

  .despots__cta:hover {
    background-color: var(--color-background);
    color: var(--color-gold);
  }

  @media (max-width: 900px) {
    .despots__inner {
      flex-direction: column;
      gap: 2rem;
      min-height: 0;
      padding: 2.5rem 1.25rem;
    }

    .despots__image-wrap {
      width: 100%;
      height: 260px;
    }

    .despots__heading {
      font-size: clamp(2.5rem, 10vw, 3.5rem);
    }

    .despots__description {
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .despots__inner {
      padding: 2rem 1.25rem;
      gap: 1.5rem;
    }

    .despots__image-wrap {
      height: 220px;
    }
  }
{% endstylesheet %}

{% schema %}
