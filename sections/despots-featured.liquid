  "name": "Uitgelicht merk",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Merkafbeelding"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label (klein)",
      "default": "Uitgelicht"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Merknaam",
      "default": "Des Pots"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Beschrijving",
      "default": "<p>Deze potten zijn geen vazen. Dit zijn <strong>karakters</strong>. Des Pots maakt stukken die een kamer direct veranderen <strong>vol kleur</strong>, <strong>vol leven</strong>, <strong>vol persoonlijkheid</strong>. Of je er bloemen in zet of niet: ze staan prachtig op zichzelf.</p>"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Knoptekst",
      "default": "Bekijk collectie"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Knoplink"
    },
    { "type": "header", "content": "Typografie" },
    { "type": "select", "id": "heading_font", "label": "Koppen — lettertype", "options": [{ "value": "inherit", "label": "— Standaard thema —" }, { "value": "'skeena', 'Cormorant Garamond', Georgia, serif", "label": "Skeena" }, { "value": "'Archivo', sans-serif", "label": "Archivo" }], "default": "inherit" },
    { "type": "select", "id": "heading_weight", "label": "Koppen — dikte", "options": [{ "value": "inherit", "label": "— Standaard —" }, { "value": "100", "label": "Thin (100)" }, { "value": "200", "label": "Extra Light (200)" }, { "value": "300", "label": "Light (300)" }, { "value": "400", "label": "Regular (400)" }, { "value": "500", "label": "Medium (500)" }, { "value": "600", "label": "SemiBold (600)" }, { "value": "700", "label": "Bold (700)" }, { "value": "800", "label": "Extra Bold (800)" }], "default": "inherit" },
    { "type": "select", "id": "heading_style", "label": "Koppen — stijl", "options": [{ "value": "inherit", "label": "— Standaard —" }, { "value": "normal", "label": "Normaal" }, { "value": "italic", "label": "Cursief" }], "default": "inherit" },
    { "type": "color", "id": "heading_color", "label": "Koppen — kleur" },
    { "type": "select", "id": "body_font", "label": "Tekst — lettertype", "options": [{ "value": "inherit", "label": "— Standaard thema —" }, { "value": "'Archivo', sans-serif", "label": "Archivo" }, { "value": "'skeena', 'Cormorant Garamond', Georgia, serif", "label": "Skeena" }], "default": "inherit" },
    { "type": "select", "id": "body_weight", "label": "Tekst — dikte", "options": [{ "value": "inherit", "label": "— Standaard —" }, { "value": "100", "label": "Thin (100)" }, { "value": "200", "label": "Extra Light (200)" }, { "value": "300", "label": "Light (300)" }, { "value": "400", "label": "Regular (400)" }, { "value": "500", "label": "Medium (500)" }, { "value": "600", "label": "SemiBold (600)" }, { "value": "700", "label": "Bold (700)" }], "default": "inherit" },
    { "type": "color", "id": "body_color", "label": "Tekst — kleur" }
  ],
  "presets": [
    {
      "name": "Uitgelicht merk"
    }
  ]
}
{% endschema %}
