{%- render 'section-typo' -%}
<section class="igram full-width"{%- if s_style != blank %} style="{{ s_style }}"{%- endif -%}>
  <div class="igram__inner">

    <div class="igram__tekst">
      <h2 class="igram__heading">
        {{ section.settings.heading | default: 'Dagelijks vers op' | escape }}<br>
        <em class="igram__handle">{{ section.settings.instagram_handle | default: '@hofvanlaren' | escape }}</em>
      </h2>
      {% if section.settings.subtitle != blank %}
        <p class="igram__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
      <a
        href="{{ section.settings.instagram_url | default: 'https://instagram.com' }}"
        target="_blank"
        rel="noopener"
        class="igram__cta"
        aria-label="Volg {{ section.settings.instagram_handle | default: '@hofvanlaren' }} op Instagram"
      >
        <svg class="igram__cta-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
          <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
        </svg>
        {{ section.settings.cta_text | default: 'Volg ons op Instagram' }}
      </a>
    </div>

    <div class="igram__fotos">
      {% for i in (1..6) %}
        {% assign img_key = 'foto_' | append: i %}
        {% assign url_key = 'url_' | append: i %}
        {% assign img_val = section.settings[img_key] %}
        {% assign url_val = section.settings[url_key] | default: section.settings.instagram_url %}
        {% if img_val != blank %}
          <a
            href="{{ url_val | default: '#' }}"
            target="_blank"
            rel="noopener"
            class="igram__foto-link"
            aria-label="Bekijk op Instagram"
          >
            <img
              src="{{ img_val | image_url: width: 400 }}"
              alt="{{ img_val.alt | default: 'Instagram foto' | escape }}"
              width="400"
              loading="lazy"
              class="igram__foto"
            >
          </a>
        {% else %}
          <div class="igram__foto-link igram__foto--leeg"></div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% stylesheet %}
  .igram {
    background-color: var(--color-foreground);
    color: var(--color-background);
    padding: 5rem 0;
  }

  .igram__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 4rem;
    align-items: center;
  }

  .igram__tekst {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .igram__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 400;
    color: var(--color-background);
    margin: 0;
    line-height: 1.2;
  }

  .igram__handle {
    font-style: italic;
    font-weight: 700;
  }

  .igram__subtitle {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(245,238,228,0.7);
    margin: 0;
    max-width: 320px;
  }

  .igram__subtitle strong, .igram__subtitle a {
    color: var(--color-background);
    font-weight: 500;
    text-decoration: none;
  }

  .igram__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-foreground);
    background-color: var(--color-background);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    border-radius: 3px;
    width: fit-content;
    letter-spacing: 0.01em;
    transition: box-shadow 0.28s cubic-bezier(0.4,0,0.2,1),
                background-color 0.22s;
  }

  .igram__cta:hover {
    box-shadow:
      0 0 0 2px var(--color-foreground),
      0 0 0 4px var(--color-background);
  }

  .igram__cta-icon {
    flex-shrink: 0;
  }

  /* Foto grid 2×3 */
  .igram__fotos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem;
  }

  .igram__foto-link {
    display: block;
    overflow: hidden;
    border-radius: var(--radius-sm);
    aspect-ratio: 1;
    background: rgba(245,238,228,0.06);
  }

  .igram__foto {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease, opacity 0.2s;
  }

  .igram__foto-link:hover .igram__foto {
    transform: scale(1.05);
    opacity: 0.9;
  }

  .igram__foto--leeg {
    background: rgba(245,238,228,0.06);
  }

  @media (max-width: 900px) {
    .igram__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 1.25rem;
    }

    .igram {
      padding: 3rem 0;
    }

    .igram__heading {
      font-size: clamp(1.8rem, 6vw, 2.6rem);
    }

    /* Horizontal scroll strip on mobile */
    .igram__fotos {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 0.5rem;
      grid-template-columns: unset;
      margin: 0 -1.25rem;
      padding: 0 1.25rem 0.75rem;
      scrollbar-width: none;
    }

    .igram__fotos::-webkit-scrollbar {
      display: none;
    }

    .igram__foto-link {
      flex: 0 0 42vw;
      max-width: 180px;
      scroll-snap-align: start;
      border-radius: var(--radius-sm);
    }
  }

  @media (max-width: 480px) {
    .igram__foto-link {
      flex: 0 0 52vw;
    }

    .igram__subtitle {
      max-width: 100%;
    }
  }
{% endstylesheet %}

