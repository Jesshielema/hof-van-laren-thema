{% style %}
  :root {
    /* Typografie — instelbaar via theme editor */
    --font-body:    {{ settings.font_body    | default: "'Archivo', 'Helvetica Neue', Arial, sans-serif" }};
    --font-heading: {{ settings.font_heading | default: "'skeena', 'Cormorant Garamond', Georgia, serif" }};

    /* Layout */
    --page-width:  1280px;
    --page-margin: {{ settings.min_page_margin | default: 20 }}px;

    /* Kleuren — instelbaar via theme editor */
    --color-background:  {{ settings.color_background | default: '#F5EEE4' }};
    --color-bg-2:        {{ settings.color_bg_2       | default: '#E9E1D8' }};
    --color-bg-3:        #D8C0A3;
    --color-border:      {{ settings.color_border     | default: '#D8C0A3' }};
    --color-foreground:  {{ settings.color_foreground | default: '#1C1410' }};
    --color-muted:       #7D6B5A;
    --color-accent:      {{ settings.color_accent     | default: '#900020' }};
    --color-accent-dark: {{ settings.color_accent     | default: '#900020' | color_darken: 15 }};
    --color-gold:        {{ settings.color_gold       | default: '#C9A85C' }};
    --color-gold-light:  {{ settings.color_gold       | default: '#C9A85C' | color_lighten: 20 }};

    /* Backwards compat */
    --color-brand-dark:   {{ settings.color_background | default: '#1C1410' }};
    --color-brand-orange: {{ settings.color_gold       | default: '#C9A85C' }};

    /* Shadows */
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.25);
    --shadow-md: 0 4px 20px rgba(0,0,0,0.35);
    --shadow-lg: 0 12px 40px rgba(0,0,0,0.45);

    /* Transitions */
    --transition: 0.22s cubic-bezier(0.4,0,0.2,1);

    /* Border radius */
    --radius:      10px;
    --radius-sm:   6px;
    --radius-pill: 100px;
  }

  {% comment %}
    Kleurschema's — één klik wisselt het volledige kleurenpalet.
    Elk schema overschrijft ALLE kleurvariabelen.
  {% endcomment %}
  {% if settings.season == 'standaard' %}
    :root {
      --color-background: #F5EEE4;
      --color-bg-2:       #E9E1D8;
      --color-border:     #D8C0A3;
      --color-foreground: #1C1410;
      --color-muted:      #7D6B5A;
      --color-gold:       #C9A85D;
      --color-gold-light: #DEC07A;
      --color-accent:     #900020;
      --color-accent-dark:#6E0018;
    }
  {% elsif settings.season == 'kerst' %}
    :root {
      --color-background: #5B0314;
      --color-bg-2:       #480210;
      --color-border:     #7A1528;
      --color-foreground: #FFFFFF;
      --color-muted:      rgba(255,255,255,0.55);
      --color-gold:       #C9A85D;
      --color-gold-light: #DEC07A;
      --color-accent:     #C9A85D;
      --color-accent-dark:#A88B48;
    }
  {% elsif settings.season == 'lente' %}
    :root {
      --color-background: #F6F1E8;
      --color-bg-2:       #EDE4D6;
      --color-border:     #D7A6A0;
      --color-foreground: #4A3A35;
      --color-muted:      #8B7068;
      --color-gold:       #C9A85D;
      --color-gold-light: #DEC07A;
      --color-accent:     #D7A6A0;
      --color-accent-dark:#BA8880;
    }
  {% elsif settings.season == 'zomer' %}
    :root {
      --color-background: #F4E9D7;
      --color-bg-2:       #EBDCC4;
      --color-border:     #D4A878;
      --color-foreground: #42352E;
      --color-muted:      #7D6250;
      --color-gold:       #C9A85D;
      --color-gold-light: #DEC07A;
      --color-accent:     #C96E4F;
      --color-accent-dark:#A85A3C;
    }
  {% elsif settings.season == 'herfst' %}
    :root {
      --color-background: #DCC8A6;
      --color-bg-2:       #CEB890;
      --color-border:     #B89A70;
      --color-foreground: #2B2523;
      --color-muted:      #6B5040;
      --color-gold:       #C9A85D;
      --color-gold-light: #DEC07A;
      --color-accent:     #7A2D2D;
      --color-accent-dark:#601C1C;
    }
  {% elsif settings.season == 'valentijn' %}
    :root {
      --color-background: #F4E7E7;
      --color-bg-2:       #EDD8D8;
      --color-border:     #C8A0A0;
      --color-foreground: #372A2A;
      --color-muted:      #7D5858;
      --color-gold:       #C9A85D;
      --color-gold-light: #DEC07A;
      --color-accent:     #7A1E2E;
      --color-accent-dark:#5E1520;
    }
  {% elsif settings.season == 'moederdag' %}
    :root {
      --color-background: #F7E9E4;
      --color-bg-2:       #EDD8D0;
      --color-border:     #D4B0A8;
      --color-foreground: #4A3A35;
      --color-muted:      #8B6860;
      --color-gold:       #C9A85D;
      --color-gold-light: #DEC07A;
      --color-accent:     #C89090;
      --color-accent-dark:#A87878;
    }
  {% endif %}
{% endstyle %}
