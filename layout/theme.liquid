<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    <!-- Skeena via Adobe Fonts (Typekit) -->
    <link rel="preconnect" href="https://use.typekit.net" crossorigin>
    <link rel="stylesheet" href="https://use.typekit.net/grm1gua.css">

    <!-- Archivo via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    {{- "https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,100..900;1,100..900&display=swap" | stylesheet_tag }}

    {% style %}

      /* ====================================================
         Per-sectie typografie-overschrijvingen
         Worden actief zodra een sectie --s-* variabelen
         instelt via een inline style attribuut.
         ==================================================== */

      /* Koppen */
      [style*="--s-font-heading"] h1,
      [style*="--s-font-heading"] h2,
      [style*="--s-font-heading"] h3,
      [style*="--s-font-heading"] [class*="__heading"],
      [style*="--s-font-heading"] [class*="__title"],
      [style*="--s-font-heading"] [class*="__quote"] {
        font-family: var(--s-font-heading) !important;
      }
      [style*="--s-weight-heading"] h1,
      [style*="--s-weight-heading"] h2,
      [style*="--s-weight-heading"] h3,
      [style*="--s-weight-heading"] [class*="__heading"],
      [style*="--s-weight-heading"] [class*="__title"],
      [style*="--s-weight-heading"] [class*="__quote"] {
        font-weight: var(--s-weight-heading) !important;
      }
      [style*="--s-style-heading"] h1,
      [style*="--s-style-heading"] h2,
      [style*="--s-style-heading"] h3,
      [style*="--s-style-heading"] [class*="__heading"],
      [style*="--s-style-heading"] [class*="__title"],
      [style*="--s-style-heading"] [class*="__quote"] {
        font-style: var(--s-style-heading) !important;
      }
      [style*="--s-color-heading"] h1,
      [style*="--s-color-heading"] h2,
      [style*="--s-color-heading"] h3,
      [style*="--s-color-heading"] [class*="__heading"],
      [style*="--s-color-heading"] [class*="__title"],
      [style*="--s-color-heading"] [class*="__quote"] {
        color: var(--s-color-heading) !important;
      }

      /* Bodytekst */
      [style*="--s-font-body"] p,
      [style*="--s-font-body"] li,
      [style*="--s-font-body"] dd,
      [style*="--s-font-body"] [class*="__body"],
      [style*="--s-font-body"] [class*="__desc"],
      [style*="--s-font-body"] [class*="__tekst"],
      [style*="--s-font-body"] [class*="__subtitle"],
      [style*="--s-font-body"] [class*="__meta"] {
        font-family: var(--s-font-body) !important;
      }
      [style*="--s-weight-body"] p,
      [style*="--s-weight-body"] li,
      [style*="--s-weight-body"] dd,
      [style*="--s-weight-body"] [class*="__body"],
      [style*="--s-weight-body"] [class*="__desc"],
      [style*="--s-weight-body"] [class*="__tekst"],
      [style*="--s-weight-body"] [class*="__subtitle"],
      [style*="--s-weight-body"] [class*="__meta"] {
        font-weight: var(--s-weight-body) !important;
      }
      [style*="--s-color-body"] p,
      [style*="--s-color-body"] li,
      [style*="--s-color-body"] dd,
      [style*="--s-color-body"] [class*="__body"],
      [style*="--s-color-body"] [class*="__desc"],
      [style*="--s-color-body"] [class*="__tekst"],
      [style*="--s-color-body"] [class*="__subtitle"],
      [style*="--s-color-body"] [class*="__meta"] {
        color: var(--s-color-body) !important;
      }
    {% endstyle %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'animations.css' | asset_url | stylesheet_tag }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body>
    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}

    <script>
    (function () {
      // --- Scroll-reveal ---
      var targets = document.querySelectorAll(
        '.shopify-section:not([class*="header"]):not([class*="footer"]) > section, ' +
        '.shopify-section:not([class*="header"]):not([class*="footer"]) > div'
      );
      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

        targets.forEach(function (el) {
          el.classList.add('reveal');
          observer.observe(el);
        });
      } else {
        targets.forEach(function (el) { el.classList.add('reveal', 'is-visible'); });
      }

      // --- Arrow nudge: wikkel → in een span ---
      document.querySelectorAll(
        '[class*="__cta"], [class*="-cta"], .btn-primary, .btn-gold'
      ).forEach(function (el) {
        el.innerHTML = el.innerHTML.replace(/(→|&rarr;|&#x2192;)/g,
          '<span class="cta-arrow" aria-hidden="true">$1</span>'
        );
      });
    })();
    </script>
  </body>
</html>
